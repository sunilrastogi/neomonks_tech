# NeoMonks Core — environment configuration
# Copy this file to `.env` and fill in real values. NEVER commit `.env`.

# ── Django core ───────────────────────────────────────────────────────────────
# Generate one with:  python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=
# "True" only for local development. Production MUST be False.
DJANGO_DEBUG=True
# Comma-separated hostnames the server may serve.
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
# Set True behind HTTPS in production to enable secure cookies / HSTS / SSL redirect.
DJANGO_SECURE=False
# Optional: comma-separated origins for CSRF (e.g. https://app.example.com)
DJANGO_CSRF_TRUSTED_ORIGINS=

# ── Database (PostgreSQL) ─────────────────────────────────────────────────────
DB_NAME=neomonks_core
DB_USER=neomonks
DB_PASSWORD=neomonks_dev
DB_HOST=localhost
DB_PORT=5432

# ── Secrets encryption (Checkpoint 2) ─────────────────────────────────────────
# Fernet key used to encrypt stored connection secrets at rest. Generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
CONFIG_ENCRYPTION_KEY=

# ── GitHub integration ────────────────────────────────────────────────────────
GITHUB_TOKEN=
GITHUB_REPO=
GITHUB_BASE_BRANCH=main

# ── LLM / agents ──────────────────────────────────────────────────────────────
DEFAULT_AGENT_MODEL=ollama/qwen2.5-coder:7b
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODELS_PATH=
OLLAMA_NUM_GPU=0
CREWAI_TRACING_ENABLED=false

# ── Loop / workers ────────────────────────────────────────────────────────────
AUTONOMOUS_MAX_WORKERS=4
LLM_TIMEOUT_SECONDS=300
LOOP_POLL_INTERVAL=10
LOOP_PR_SYNC_INTERVAL=3600
